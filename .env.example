# Copy to `.env` and adjust. Never commit `.env` or files under `.secrets/`.

# GCP (Vertex + client libraries often read GOOGLE_CLOUD_PROJECT)
GCP_PROJECT_ID=sport-data-campus
GOOGLE_CLOUD_PROJECT=sport-data-campus

# Vertex AI Generative (region; use `global` if supported for your model)
VERTEX_LOCATION=global
VERTEX_MODEL_NAME=gemini-2.5-flash-lite

# Service account key (path relative to repo root or absolute)
GOOGLE_APPLICATION_CREDENTIALS=.secrets/vertexai-wyscout.json

# BigQuery dataset (pipeline / queries)
BIGQUERY_DATASET=scouting_agent
